generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(LAWYER)
  createdAt DateTime @default(now())
}

model Process {
  id        String   @id @default(uuid())
  number    String
  client    String
  status    ProcessStatus @default(ACTIVE)
  createdAt DateTime @default(now())

  movements Movement[]
}

model Movement {
  id        String   @id @default(uuid())
  title     String
  createdAt DateTime @default(now())

  processId String
  process   Process @relation(fields: [processId], references: [id])
}

enum Role {
  ADMIN
  LAWYER
  ASSISTANT
}

enum ProcessStatus {
  ACTIVE
  CLOSED
  SUSPENDED
}